---
import '../styles/global.css';
import { url } from '../utils/url';
import { LANG_CODE, UI, ALL_PSALMS_PATH } from '../utils/i18n';
import type { TranslationId } from '../utils/i18n';

interface Props {
  title: string;
  description?: string;
  translation?: TranslationId;
}

const { title, description = 'A different Psalm each day from the World English Bible.', translation = 'web' } = Astro.props;
const ui = UI[translation];
---
<!doctype html>
<html lang={LANG_CODE[translation]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <main>
      <header class="site-header">
        <a href={url('/')}>{ui.siteTitle}</a>
        <a href={url(ALL_PSALMS_PATH[translation])}>{ui.allPsalms}</a>
      </header>
      <slot />
    </main>
  </body>
</html>
