---
import '../styles/global.css';
import { url } from '../utils/url';
import { LANG_CODE, UI } from '../utils/i18n';
import type { TranslationId } from '../utils/i18n';

interface Props {
  title: string;
  description?: string;
  translation?: TranslationId;
}

const { title, description = 'A different Psalm each day from the World English Bible.', translation = 'web' } = Astro.props;
const ui = UI[translation];
---
<!doctype html>
<html lang={LANG_CODE[translation]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Lora:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <header class="site-header">
        <a href={url('/')}>{ui.siteTitle}</a>
        <a href={url('/psalms')}>{ui.allPsalms}</a>
      </header>
      <slot />
    </main>
  </body>
</html>
