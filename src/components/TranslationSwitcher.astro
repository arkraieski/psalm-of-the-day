---
import { url } from '../utils/url';
import { UI } from '../utils/i18n';
export type { TranslationId } from '../utils/i18n';

interface Props {
  psalmNumber: number;
  current: TranslationId;
}

const { psalmNumber, current } = Astro.props;

const translations: Array<{ id: TranslationId; label: string; path: string }> = [
  { id: 'web', label: 'World English Bible',      path: url(`/psalms/${psalmNumber}`) },
  { id: 'kjv', label: 'King James Version',        path: url(`/psalms/kjv/${psalmNumber}`) },
  { id: 'es',  label: 'Español — Reina Valera',    path: url(`/psalms/es/${psalmNumber}`) },
  { id: 'it',  label: 'Italiano — Riveduta',        path: url(`/psalms/it/${psalmNumber}`) },
  { id: 'pl',  label: 'Polski — Polska Biblia',     path: url(`/psalms/pl/${psalmNumber}`) },
  { id: 'pt',  label: 'Português — Versão Portuguesa', path: url(`/psalms/pt/${psalmNumber}`) },
  { id: 'zh',  label: '中文 — 中文和合本',           path: url(`/psalms/zh/${psalmNumber}`) },
];
---
<div class="translation-switcher">
  <select class="translation-select" aria-label={UI[current].translation}>
    {translations.map(t => (
      <option value={t.path} data-id={t.id} selected={t.id === current}>
        {t.label}
      </option>
    ))}
  </select>
</div>
<script>
  const sel = document.querySelector<HTMLSelectElement>('.translation-select');
  sel?.addEventListener('change', () => {
    const opt = sel.options[sel.selectedIndex] as HTMLOptionElement & { dataset: DOMStringMap };
    localStorage.setItem('favored-translation', opt.dataset.id ?? 'web');
    window.location.href = sel.value;
  });
</script>
