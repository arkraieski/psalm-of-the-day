---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Psalm of the Day">
  <p class="loading-text">Loading today's Psalm…</p>
  <script define:vars={{ base: import.meta.env.BASE_URL }}>
    const now = new Date();
    const start = new Date(now.getFullYear(), 0, 1);
    const dayOfYear = Math.ceil((now - start) / 86400000) + 1;
    const n = ((dayOfYear - 1) % 150) + 1;
    const translation = localStorage.getItem('favored-translation') === 'kjv' ? 'kjv' : 'web';
    const psalmPath = translation === 'kjv' ? `/psalms/kjv/${n}` : `/psalms/${n}`;
    const psalmUrl = base.replace(/\/$/, '') + psalmPath;

    fetch(psalmUrl)
      .then(r => r.text())
      .then(html => {
        const doc = new DOMParser().parseFromString(html, 'text/html');
        const article = doc.querySelector('article');
        if (article) {
          document.querySelector('.loading-text').replaceWith(article);
          document.title = doc.title;
        } else {
          window.location.replace(psalmUrl);
        }
      })
      .catch(() => window.location.replace(psalmUrl));
  </script>
  <noscript>
    <p>Enable JavaScript to see today's Psalm, or <a href="psalms/">browse all 150 Psalms</a>.</p>
  </noscript>
</BaseLayout>
