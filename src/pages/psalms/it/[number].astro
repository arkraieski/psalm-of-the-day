---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PsalmDisplay from '../../../components/PsalmDisplay.astro';
import { url } from '../../../utils/url';
import { UI, ALL_PSALMS_PATH } from '../../../utils/i18n';
const ui = UI['it'];

export async function getStaticPaths() {
  const psalms = await getCollection('psalmsIt');
  return psalms.map(p => ({
    params: { number: String(p.data.number) },
  }));
}

const { number } = Astro.params;
const psalm = await getEntry('psalmsIt', number);
if (!psalm) return Astro.redirect(url('/psalms'));

const n = psalm.data.number;
---
<BaseLayout
  title={`Psalm ${n} (Riveduta) — Psalm of the Day`}
  description={`Psalm ${n} in Italian, Riveduta.`}
  translation="it"
>
  <PsalmDisplay psalm={psalm} translation="it" />
  <nav class="psalm-nav">
    {n > 1 && <a href={url(`/psalms/it/${n - 1}`)}>← {ui.psalm} {n - 1}</a>}
    <a href={url(ALL_PSALMS_PATH['it'])}>{ui.allPsalms}</a>
    {n < 150 && <a href={url(`/psalms/it/${n + 1}`)}>{ui.psalm} {n + 1} →</a>}
  </nav>
</BaseLayout>
