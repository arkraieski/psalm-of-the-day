---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PsalmDisplay from '../../../components/PsalmDisplay.astro';
import { url } from '../../../utils/url';

export async function getStaticPaths() {
  const psalms = await getCollection('psalmsKjv');
  return psalms.map(p => ({
    params: { number: String(p.data.number) },
  }));
}

const { number } = Astro.params;
const psalm = await getEntry('psalmsKjv', number);
if (!psalm) return Astro.redirect(url('/psalms'));

const n = psalm.data.number;
---
<BaseLayout
  title={`Psalm ${n} (KJV) — Psalm of the Day`}
  description={`Psalm ${n} from the King James Bible.`}
>
  <PsalmDisplay psalm={psalm} translation="kjv" />
  <nav class="psalm-nav">
    {n > 1 && <a href={url(`/psalms/kjv/${n - 1}`)}>← Psalm {n - 1}</a>}
    <a href={url('/psalms')}>All Psalms</a>
    {n < 150 && <a href={url(`/psalms/kjv/${n + 1}`)}>Psalm {n + 1} →</a>}
  </nav>
</BaseLayout>
