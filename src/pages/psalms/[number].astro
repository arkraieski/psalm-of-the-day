---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PsalmDisplay from '../../components/PsalmDisplay.astro';
import { url } from '../../utils/url';

export async function getStaticPaths() {
  const psalms = await getCollection('psalms');
  return psalms.map(p => ({
    params: { number: String(p.data.number) },
  }));
}

const { number } = Astro.params;
const psalm = await getEntry('psalms', number);
if (!psalm) return Astro.redirect(url('/psalms'));

const n = psalm.data.number;
---
<BaseLayout
  title={`Psalm ${n} — Psalm of the Day`}
  description={psalm.data.title ?? `Psalm ${n} from the World English Bible.`}
>
  <PsalmDisplay psalm={psalm} translation="web" />
  <nav class="psalm-nav">
    {n > 1 && <a href={url(`/psalms/${n - 1}`)}>← Psalm {n - 1}</a>}
    <a href={url('/psalms')}>All Psalms</a>
    {n < 150 && <a href={url(`/psalms/${n + 1}`)}>Psalm {n + 1} →</a>}
  </nav>
</BaseLayout>
