---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PsalmDisplay from '../../../components/PsalmDisplay.astro';
import { url } from '../../../utils/url';

export async function getStaticPaths() {
  const psalms = await getCollection('psalmsPt');
  return psalms.map(p => ({
    params: { number: String(p.data.number) },
  }));
}

const { number } = Astro.params;
const psalm = await getEntry('psalmsPt', number);
if (!psalm) return Astro.redirect(url('/psalms'));

const n = psalm.data.number;
---
<BaseLayout
  title={`Psalm ${n} (Versão Portuguesa) — Psalm of the Day`}
  description={`Psalm ${n} in Portuguese, Versão Portuguesa.`}
>
  <PsalmDisplay psalm={psalm} translation="pt" />
  <nav class="psalm-nav">
    {n > 1 && <a href={url(`/psalms/pt/${n - 1}`)}>← Psalm {n - 1}</a>}
    <a href={url('/psalms')}>All Psalms</a>
    {n < 150 && <a href={url(`/psalms/pt/${n + 1}`)}>Psalm {n + 1} →</a>}
  </nav>
</BaseLayout>
